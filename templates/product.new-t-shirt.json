            "custom_liquid_Vcd68Q": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<div style=\"margin: 5px 0;\">\n  <script>\n    document.addEventListener('DOMContentLoaded', function() {\n      // Get current product URL and extract the handle\n      const currentUrl = window.location.pathname;\n      const urlParts = currentUrl.split('/');\n      const currentHandle = urlParts[urlParts.length - 1];\n      \n      // Build the corresponding product URL\n      let targetUrl = '';\n      let linkText = '';\n      \n      if (currentHandle.startsWith('new-hoodie-') || currentHandle.startsWith('hudijs-')) {\n        // If on hoodie page, link to t-shirt\n        let baseHandle = '';\n        if (currentHandle.startsWith('new-hoodie-')) {\n          baseHandle = currentHandle.replace(/^new-hoodie-/, '');\n          targetUrl = `/products/new-t-shirt-${baseHandle}`;\n        } else if (currentHandle.startsWith('hudijs-')) {\n          baseHandle = currentHandle.replace(/^hudijs-/, '');\n          targetUrl = `/products/t-krekls-${baseHandle}`;\n        }\n        linkText = 'T-krekls ar šādu dizainu';\n      } else if (currentHandle.startsWith('new-t-shirt-') || currentHandle.startsWith('t-krekls-')) {\n        // If on t-shirt page, link to hoodie\n        let baseHandle = '';\n        if (currentHandle.startsWith('new-t-shirt-')) {\n          baseHandle = currentHandle.replace(/^new-t-shirt-/, '');\n          targetUrl = `/products/new-hoodie-${baseHandle}`;\n        } else if (currentHandle.startsWith('t-krekls-')) {\n          baseHandle = currentHandle.replace(/^t-krekls-/, '');\n          targetUrl = `/products/hudijs-${baseHandle}`;\n        }\n        linkText = 'Hūdijs ar šādu dizainu';\n      } else {\n        // Default case for hoodie template\n        linkText = 'T-krekls ar šādu dizainu';\n        targetUrl = `/products/t-krekls-${currentHandle}`;\n      }\n      \n      // Create and insert the link\n      const container = document.querySelector('[data-variant-link]');\n      if (container && targetUrl) {\n        container.innerHTML = `<a href=\"${targetUrl}\" style=\"color: #000; text-decoration: underline; font-size: 14px;\">${linkText}</a>`;\n      }\n    });\n  </script>\n  <div data-variant-link></div>\n</div>"
              },
              "blocks": {}
            },
            "custom_liquid_XzbMc3": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<style>\n  .cfw {\n    margin-block: var(--gap-md, 16px) 0;\n    display: flex;\n    flex-direction: column;\n    gap: var(--gap-sm, 8px);\n  }\n\n  .cfw__section {\n    border-radius: var(--style-border-radius-buttons-secondary);\n    overflow: hidden;\n  }\n\n  .cfw__section:not(.cfw__section--collapsed) {\n    box-shadow: inset 0 0 0 var(--style-border-width-secondary, 1px) var(--color-foreground);\n  }\n\n  .cfw__header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: var(--button-padding-block, 12px) var(--button-padding-inline, 20px);\n    background-color: var(--color-foreground);\n    cursor: pointer;\n    user-select: none;\n    gap: 8px;\n  }\n\n  .cfw__title {\n    font-family: var(--font-paragraph--family);\n    font-size: var(--font-paragraph--size);\n    font-weight: var(--font-paragraph--weight);\n    color: var(--color-background);\n    margin: 0;\n  }\n\n  .cfw__chevron {\n    color: var(--color-background);\n    font-size: 12px;\n    transition: transform var(--animation-speed, 0.2s) ease;\n    line-height: 1;\n  }\n\n  .cfw__section--collapsed .cfw__chevron {\n    transform: rotate(-90deg);\n  }\n\n  .cfw__body {\n    padding: var(--button-padding-inline, 20px);\n    display: flex;\n    flex-direction: column;\n    gap: var(--gap-sm, 8px);\n    background-color: var(--color-background);\n  }\n\n  .cfw__section--collapsed .cfw__body {\n    display: none;\n  }\n\n  .cfw__input[type=\"file\"] {\n    display: none;\n  }\n\n  .cfw__input[type=\"text\"] {\n    width: 100%;\n    border-radius: var(--style-border-radius-buttons-secondary);\n    padding: var(--input-padding);\n    box-shadow: var(--input-box-shadow);\n    background-color: var(--color-input-background);\n    color: var(--color-input-text);\n    border: none;\n    outline: none;\n    font-family: var(--font-paragraph--family);\n    font-size: var(--font-paragraph--size);\n    transition: box-shadow var(--animation-speed) ease;\n    box-sizing: border-box;\n  }\n\n  .cfw__input[type=\"text\"]:is(:focus, :hover) {\n    box-shadow: var(--input-box-shadow-focus);\n    background-color: var(--color-input-hover-background);\n  }\n\n  .cfw__upload-btn,\n  .cfw__add-btn {\n    width: 100%;\n    display: block;\n    text-align: center;\n    cursor: pointer;\n    font-family: var(--button-font-family-secondary, var(--font-paragraph--family));\n    font-size: var(--font-paragraph--size);\n    font-weight: var(--font-paragraph--weight);\n    text-transform: var(--button-text-case-secondary, none);\n    color: var(--color-secondary-button-text);\n    background-color: var(--color-secondary-button-background);\n    box-shadow: inset 0 0 0 var(--style-border-width-secondary, 1px) var(--color-secondary-button-border);\n    border-radius: var(--style-border-radius-buttons-secondary);\n    padding-block: var(--button-padding-block, 12px);\n    padding-inline: var(--button-padding-inline, 20px);\n    border: none;\n    transition: color var(--animation-speed) ease,\n      box-shadow var(--animation-speed) ease,\n      background-color var(--animation-speed) ease;\n  }\n\n  .cfw__upload-btn:hover,\n  .cfw__add-btn:hover {\n    color: var(--color-secondary-button-hover-text);\n    background-color: var(--color-secondary-button-hover-background);\n    box-shadow: inset 0 0 0 var(--style-border-width-secondary, 1px) var(--color-secondary-button-hover-border);\n  }\n\n  .cfw__preview-wrap {\n    position: relative;\n    display: inline-block;\n    border-radius: var(--style-border-radius-buttons-secondary);\n    overflow: hidden;\n    box-shadow: inset 0 0 0 var(--style-border-width-secondary, 1px) var(--color-foreground);\n  }\n\n  .cfw__preview-img {\n    display: block;\n    max-width: 160px;\n    max-height: 160px;\n    width: auto;\n    height: auto;\n    object-fit: contain;\n  }\n\n  .cfw__remove-btn {\n    position: absolute;\n    top: 6px;\n    right: 6px;\n    background-color: var(--color-foreground);\n    color: var(--color-background);\n    border: none;\n    border-radius: 50%;\n    width: 24px;\n    height: 24px;\n    font-size: 14px;\n    line-height: 1;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .cfw__filename {\n    font-family: var(--font-paragraph--family);\n    font-size: calc(var(--font-paragraph--size) * 0.85);\n    color: rgb(var(--color-foreground-rgb) / var(--opacity-70, 0.7));\n    margin-top: 4px;\n    word-break: break-all;\n  }\n</style>\n\n<div class=\"cfw\">\n\n  <!-- Front Section — open by default -->\n  <div class=\"cfw__section\" id=\"front-section\">\n    <div class=\"cfw__header\" onclick=\"cfwToggle('front')\">\n      <span class=\"cfw__title\">Priekša</span>\n      <span class=\"cfw__chevron\">▼</span>\n    </div>\n    <div class=\"cfw__body\">\n      <input class=\"cfw__input\" type=\"file\" id=\"front-file\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Priekša - Foto]\" accept=\"image/*\" onchange=\"handleFileUpload(this, 'front')\" />\n      <label for=\"front-file\" class=\"cfw__upload-btn\" id=\"front-upload-btn\">Augšupielādē foto priekšai</label>\n      <div id=\"front-file-display\"></div>\n      <input class=\"cfw__input\" type=\"text\" id=\"front-text\" placeholder=\"Teksts priekšai\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Priekša - Teksts]\" />\n      <input class=\"cfw__input\" type=\"text\" id=\"front-info\" placeholder=\"Papildus info par novietojumu priekšā\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Priekša - Papildus info]\" />\n    </div>\n  </div>\n\n  <!-- Back Section — collapsed by default -->\n  <div class=\"cfw__section cfw__section--collapsed\" id=\"back-section\">\n    <div class=\"cfw__header\" onclick=\"cfwToggle('back')\">\n      <span class=\"cfw__title\">Aizmugure</span>\n      <span class=\"cfw__chevron\">▼</span>\n    </div>\n    <div class=\"cfw__body\">\n      <input class=\"cfw__input\" type=\"file\" id=\"back-file\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Aizmugure - Foto]\" accept=\"image/*\" onchange=\"handleFileUpload(this, 'back')\" />\n      <label for=\"back-file\" class=\"cfw__upload-btn\" id=\"back-upload-btn\">Augšupielādē foto aizmugurei</label>\n      <div id=\"back-file-display\"></div>\n      <input class=\"cfw__input\" type=\"text\" id=\"back-text\" placeholder=\"Teksts aizmugurei\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Aizmugure - Teksts]\" />\n      <input class=\"cfw__input\" type=\"text\" id=\"back-info\" placeholder=\"Papildus info par novietojumu aizmugurē\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Aizmugure - Papildus info]\" />\n    </div>\n  </div>\n\n</div>\n\n<script>\nfunction cfwToggle(s) {\n  const section = document.getElementById(s + '-section');\n  const collapsed = section.classList.toggle('cfw__section--collapsed');\n  if (collapsed) clearFormInputs(s);\n}\n\nfunction clearFormInputs(s) {\n  document.getElementById(s + '-file').value = '';\n  document.getElementById(s + '-text').value = '';\n  document.getElementById(s + '-info').value = '';\n  document.getElementById(s + '-file-display').innerHTML = '';\n  document.getElementById(s + '-upload-btn').style.display = 'block';\n}\n\nfunction handleFileUpload(input, s) {\n  const file = input.files[0];\n  if (!file || !file.type.startsWith('image/')) return;\n\n  let name = file.name;\n  if (name.length > 27) {\n    const ext = name.split('.').pop();\n    name = name.substring(0, 20) + '...' + ext;\n  }\n\n  const reader = new FileReader();\n  reader.onload = function(e) {\n    document.getElementById(s + '-file-display').innerHTML =\n      `<div class=\"cfw__preview-wrap\">\n        <img src=\"${e.target.result}\" class=\"cfw__preview-img\" alt=\"Preview\" />\n        <button type=\"button\" class=\"cfw__remove-btn\" onclick=\"removeFile('${s}')\" aria-label=\"Noņemt\">×</button>\n      </div>\n      <div class=\"cfw__filename\">${name}</div>`;\n    document.getElementById(s + '-upload-btn').style.display = 'none';\n  };\n  reader.readAsDataURL(file);\n}\n\nfunction removeFile(s) {\n  document.getElementById(s + '-file').value = '';\n  document.getElementById(s + '-file-display').innerHTML = '';\n  document.getElementById(s + '-upload-btn').style.display = 'block';\n}\n</script>"
