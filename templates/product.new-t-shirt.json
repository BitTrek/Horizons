              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<style>\n.custom-forms-wrapper {\n    margin: 20px 0;\n}\n.custom-form-section {\n    margin-bottom: 15px;\n    border-radius: 15px;\n    overflow: hidden;\n    border: calc(var(--buttons-border-width) * 0.7) solid black;\n    transition: all 0.3s ease;\n}\n.custom-form-section.active {\n    border-color: black;\n}\n.form-section-header {\n    background: linear-gradient(135deg, #40e0d0, #9b59b6, #ff8c00, #ff0080);\n    padding: 15px 20px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    cursor: pointer;\n    color: white;\n    font-weight: 100;\n}\n.form-section-title {\n    font-size: 16px;\n    color: black;\n    font-weight: 100;\n}\n.form-section-toggle {\n    background: rgba(255,255,255,0.2);\n    border: none;\n    color: black;\n    padding: 8px;\n    border-radius: 50%;\n    cursor: pointer;\n    font-size: 16px;\n    font-weight: bold;\n    width: 32px;\n    height: 32px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    line-height: 1;\n}\n.form-section-content {\n    padding: 20px;\n    background: linear-gradient(135deg, rgba(64, 224, 208, 0.05), rgba(155, 89, 182, 0.05), rgba(255, 140, 0, 0.05), rgba(255, 0, 128, 0.05));\n    display: block;\n}\n.form-section-content.hidden {\n    display: none;\n}\n.custom-form-field {\n    margin-bottom: 15px;\n}\n.custom-form-label {\n    display: block;\n    margin-bottom: 8px;\n    font-weight: 100;\n    color: #121212;\n    font-size: 14px;\n}\n.custom-form-input {\n    width: 100%;\n    padding: 12px 16px;\n    border: calc(var(--buttons-border-width) * 0.5) solid black;\n    border-radius: 25px;\n    font-size: 14px;\n    transition: all 0.3s ease;\n    background: white;\n}\n.custom-form-input:focus {\n    outline: none;\n    border-color: #40e0d0;\n    box-shadow: 0 0 0 3px rgba(64, 224, 208, 0.2);\n}\n.custom-form-input[type=\"file\"] {\n    display: none;\n}\n.file-upload-btn {\n    background: linear-gradient(45deg, #40e0d0, #9b59b6, #ff8c00, #ff0080);\n    border: calc(var(--buttons-border-width) * 0.7) solid black;\n    color: black;\n    padding: 12px 16px;\n    border-radius: 25px;\n    cursor: pointer;\n    font-weight: 600;\n    width: 100%;\n    text-align: center;\n    display: inline-block;\n    margin-bottom: 10px;\n    font-size: 14px;\n}\n.image-preview-container {\n    position: relative;\n    max-width: 200px;\n    max-height: 200px;\n    border: calc(var(--buttons-border-width) * 0.7) solid black;\n    border-radius: 15px;\n    overflow: hidden;\n    margin-bottom: 5px;\n    display: inline-block;\n}\n.image-filename {\n    font-size: 12px;\n    color: #666;\n    text-align: center;\n    margin-bottom: 10px;\n    word-break: break-all;\n}\n.image-preview {\n    max-width: 200px;\n    max-height: 200px;\n    width: auto;\n    height: auto;\n    object-fit: contain;\n    display: block;\n}\n.remove-image-btn {\n    position: absolute;\n    top: 8px;\n    right: 8px;\n    background: #ff6968;\n    border: none;\n    color: black;\n    padding: 6px;\n    border-radius: 50%;\n    cursor: pointer;\n    font-size: 16px;\n    font-weight: bold;\n    width: 28px;\n    height: 28px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    line-height: 1;\n}\n.show-section-btn {\n    background: linear-gradient(45deg, #40e0d0, #9b59b6, #ff8c00, #ff0080);\n    border: calc(var(--buttons-border-width) * 0.7) solid black;\n    color: black;\n    padding: 12px 20px;\n    border-radius: 25px;\n    cursor: pointer;\n    font-weight: 100;\n    margin-bottom: 15px;\n    width: 100%;\n}\n</style>\n\n<div class=\"custom-forms-wrapper\">\n    <!-- Front Section -->\n    <div class=\"custom-form-section active\" id=\"front-section\">\n        <div class=\"form-section-header\" onclick=\"toggleSection('front')\">\n            <span class=\"form-section-title\">Priekša</span>\n            <button type=\"button\" class=\"form-section-toggle\" onclick=\"event.stopPropagation(); closeSection('front')\">×</button>\n        </div>\n        <div class=\"form-section-content\" id=\"front-content\">\n            <div class=\"custom-form-field\">\n                <input class=\"custom-form-input\" type=\"file\" id=\"front-file\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Priekša - Foto]\" accept=\"image/*\" onchange=\"handleFileUpload(this, 'front')\" />\n                <label for=\"front-file\" class=\"file-upload-btn\" id=\"front-upload-btn\">Augšupielādē foto priekšai</label>\n                <div id=\"front-file-display\"></div>\n            </div>\n            <div class=\"custom-form-field\">\n                <input class=\"custom-form-input\" type=\"text\" id=\"front-text\" placeholder=\"Ievadi tekstu priekšai\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Priekša - Teksts]\" />\n            </div>\n            <div class=\"custom-form-field\">\n                <input class=\"custom-form-input\" type=\"text\" id=\"front-info\" placeholder=\"Papildus info par novietojumu priekšā\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Priekša - Papildus info]\" />\n            </div>\n        </div>\n    </div>\n\n    <!-- Show Front Button (hidden by default) -->\n    <button type=\"button\" class=\"show-section-btn\" id=\"show-front-btn\" onclick=\"showSection('front')\" style=\"display: none;\">\n        + Pievienot apdrukas priekšai\n    </button>\n\n    <!-- Back Section -->\n    <div class=\"custom-form-section\" id=\"back-section\" style=\"display: none;\">\n        <div class=\"form-section-header\" onclick=\"toggleSection('back')\">\n            <span class=\"form-section-title\">Aizmugure</span>\n            <button type=\"button\" class=\"form-section-toggle\" onclick=\"event.stopPropagation(); closeSection('back')\">×</button>\n        </div>\n        <div class=\"form-section-content\" id=\"back-content\">\n            <div class=\"custom-form-field\">\n                <input class=\"custom-form-input\" type=\"file\" id=\"back-file\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Aizmugure - Foto]\" accept=\"image/*\" onchange=\"handleFileUpload(this, 'back')\" />\n                <label for=\"back-file\" class=\"file-upload-btn\" id=\"back-upload-btn\">Augšupielādē foto aizmugurei</label>\n                <div id=\"back-file-display\"></div>\n            </div>\n            <div class=\"custom-form-field\">\n                <input class=\"custom-form-input\" type=\"text\" id=\"back-text\" placeholder=\"Ievadi tekstu aizmugurei\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Aizmugure - Teksts]\" />\n            </div>\n            <div class=\"custom-form-field\">\n                <input class=\"custom-form-input\" type=\"text\" id=\"back-info\" placeholder=\"Papildus info par novietojumu aizmugurē\" form=\"BuyButtons-ProductForm-{{ section.id }}\" name=\"properties[Aizmugure - Papildus info]\" />\n            </div>\n        </div>\n    </div>\n\n    <!-- Show Back Button (visible by default) -->\n    <button type=\"button\" class=\"show-section-btn\" id=\"show-back-btn\" onclick=\"showSection('back')\" style=\"display: block;\">\n        + Pievienot apdrukas aizmugurei\n    </button>\n</div>\n\n<script>\n    function toggleSection(section) {\n    const frontSection = document.getElementById('front-section');\n    const backSection = document.getElementById('back-section');\n\n    if (section === 'front') {\n    if (frontSection.style.display === 'none') {\n    showSection('front');\n}\n} else if (section === 'back') {\n    if (backSection.style.display === 'none') {\n    showSection('back');\n}\n}\n}\n\n    function closeSection(section) {\n    const frontSection = document.getElementById('front-section');\n    const backSection = document.getElementById('back-section');\n    const frontContent = document.getElementById('front-content');\n    const backContent = document.getElementById('back-content');\n    const showFrontBtn = document.getElementById('show-front-btn');\n    const showBackBtn = document.getElementById('show-back-btn');\n\n    // Check if both sections are currently open\n    const frontOpen = frontSection.style.display !== 'none';\n    const backOpen = backSection.style.display !== 'none';\n\n    // Only allow closing if the other section is open\n    if (section === 'front' && backOpen) {\n    frontSection.style.display = 'none';\n    showFrontBtn.style.display = 'block';\n    clearFormInputs('front');\n} else if (section === 'back' && frontOpen) {\n    backSection.style.display = 'none';\n    showBackBtn.style.display = 'block';\n    clearFormInputs('back');\n}\n}\n\n    function showSection(section) {\n    const frontSection = document.getElementById('front-section');\n    const backSection = document.getElementById('back-section');\n    const showFrontBtn = document.getElementById('show-front-btn');\n    const showBackBtn = document.getElementById('show-back-btn');\n\n    if (section === 'front') {\n    frontSection.style.display = 'block';\n    frontSection.classList.add('active');\n    showFrontBtn.style.display = 'none';\n} else if (section === 'back') {\n    backSection.style.display = 'block';\n    backSection.classList.add('active');\n    showBackBtn.style.display = 'none';\n}\n}\n\n    function clearFormInputs(section) {\n    if (section === 'front') {\n    document.getElementById('front-file').value = '';\n    document.getElementById('front-text').value = '';\n    document.getElementById('front-info').value = '';\n    document.getElementById('front-file-display').innerHTML = '';\n    document.getElementById('front-upload-btn').style.display = 'inline-block';\n    document.getElementById('front-file-label').style.display = 'block';\n} else if (section === 'back') {\n    document.getElementById('back-file').value = '';\n    document.getElementById('back-text').value = '';\n    document.getElementById('back-info').value = '';\n    document.getElementById('back-file-display').innerHTML = '';\n    document.getElementById('back-upload-btn').style.display = 'inline-block';\n    document.getElementById('back-file-label').style.display = 'block';\n}\n}\n\n    function handleFileUpload(input, section) {\n    const file = input.files[0];\n    const displayDiv = document.getElementById(section + '-file-display');\n    const uploadBtn = document.getElementById(section + '-upload-btn');\n    const fileLabel = document.getElementById(section + '-file-label');\n\n    if (file && file.type.startsWith('image/')) {\n    // Truncate filename if longer than 27 characters\n    let displayName = file.name;\n    if (displayName.length > 27) {\n    const extension = displayName.split('.').pop();\n    const nameWithoutExt = displayName.substring(0, displayName.lastIndexOf('.'));\n    const truncatedName = nameWithoutExt.substring(0, 23 - extension.length) + '...';\n    displayName = truncatedName + '.' + extension;\n}\n\n    const reader = new FileReader();\n    reader.onload = function(e) {\n    displayDiv.innerHTML = `\n        <div class=\"image-preview-container\">\n          <img src=\"${e.target.result}\" alt=\"Preview\" class=\"image-preview\" />\n          <button type=\"button\" class=\"remove-image-btn\" onclick=\"removeFile('${section}')\" title=\"Noņemt foto\">×</button>\n        </div>\n        <div class=\"image-filename\">${displayName}</div>\n      `;\n    uploadBtn.style.display = 'none';\n    fileLabel.style.display = 'none';\n};\n    reader.readAsDataURL(file);\n}\n}\n\n    function removeFile(section) {\n    const fileInput = document.getElementById(section + '-file');\n    const displayDiv = document.getElementById(section + '-file-display');\n    const uploadBtn = document.getElementById(section + '-upload-btn');\n    const fileLabel = document.getElementById(section + '-file-label');\n\n    fileInput.value = '';\n    displayDiv.innerHTML = '';\n    uploadBtn.style.display = 'inline-block';\n    fileLabel.style.display = 'block';\n\n\n}\n\n    // Clean custom form functionality - no validation interference\n    document.addEventListener('DOMContentLoaded', function() {\n    console.log('✅ Custom form loaded - no validation interference');\n});\n</script>"
