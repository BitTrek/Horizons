            "custom_liquid_Vcd68Q": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<div style=\"margin: 5px 0;\">\n  <script>\n    document.addEventListener('DOMContentLoaded', function() {\n      // Get current product URL and extract the handle\n      const currentUrl = window.location.pathname;\n      const urlParts = currentUrl.split('/');\n      const currentHandle = urlParts[urlParts.length - 1];\n      \n      // Build the corresponding product URL\n      let targetUrl = '';\n      let linkText = '';\n      \n      if (currentHandle.startsWith('new-hoodie-') || currentHandle.startsWith('hudijs-')) {\n        // If on hoodie page, link to t-shirt\n        let baseHandle = '';\n        if (currentHandle.startsWith('new-hoodie-')) {\n          baseHandle = currentHandle.replace(/^new-hoodie-/, '');\n          targetUrl = `/products/new-t-shirt-${baseHandle}`;\n        } else if (currentHandle.startsWith('hudijs-')) {\n          baseHandle = currentHandle.replace(/^hudijs-/, '');\n          targetUrl = `/products/t-krekls-${baseHandle}`;\n        }\n        linkText = 'T-krekls ar šādu dizainu';\n      } else if (currentHandle.startsWith('new-t-shirt-') || currentHandle.startsWith('t-krekls-')) {\n        // If on t-shirt page, link to hoodie\n        let baseHandle = '';\n        if (currentHandle.startsWith('new-t-shirt-')) {\n          baseHandle = currentHandle.replace(/^new-t-shirt-/, '');\n          targetUrl = `/products/new-hoodie-${baseHandle}`;\n        } else if (currentHandle.startsWith('t-krekls-')) {\n          baseHandle = currentHandle.replace(/^t-krekls-/, '');\n          targetUrl = `/products/hudijs-${baseHandle}`;\n        }\n        linkText = 'Hūdijs ar šādu dizainu';\n      } else {\n        // Default case for hoodie template\n        linkText = 'T-krekls ar šādu dizainu';\n        targetUrl = `/products/t-krekls-${currentHandle}`;\n      }\n      \n      // Create and insert the link\n      const container = document.querySelector('[data-variant-link]');\n      if (container && targetUrl) {\n        container.innerHTML = `<a href=\"${targetUrl}\" style=\"color: #000; text-decoration: underline; font-size: 14px;\">${linkText}</a>`;\n      }\n    });\n  </script>\n  <div data-variant-link></div>\n</div>"
              },
              "blocks": {}
            },
